{% extends 'base.html.twig' %}

{% block title %}Hello Admin!{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" type="text/css" href="{{ asset('simditor-2.3.28/styles/simditor.css') }}" />
{% endblock %}

{% block body %}
    {{ parent() }}

    {% if th_keys|length %}
        <!-- Table -->
        <table id='telegramUserTable' class='display dataTable'>

            <thead>
            <tr>
                {% for th_key in th_keys %}
                    <th scope="col">{{ th_key }}</th>
                {% endfor %}
            </tr>
            </thead>
            <tfoot>
            {% for th_key in th_keys %}
                <th scope="col">{{ th_key }}</th>
            {% endfor %}
            </tfoot>

        </table>
    {% endif %}

    <!-- Modal -->
    <div class="modal fade" id="exampleModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Редагування</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form id="telegramUserForm">
                        <div class="form-group">
                            <label for="account_number" class="col-form-label">Особовий рахунок</label>
                            <input type="text" id="account_number" class="form-control" name="account[account_number]"/>
                        </div>
                        <div class="form-group">
                            <label for="apartment_number" class="col-form-label">Номер квартири</label>
                            <input type="text" id="apartment_number" class="form-control" name="account[apartment_number]"/>
                        </div>
                        <div class="form-group">
                            <label for="house_number" class="col-form-label">Номер будинку</label>
                            <input type="text" id="house_number" class="form-control" name="account[house_number]"/>
                        </div>
                        <div class="form-group">
                            <label for="street" class="col-form-label">Вулиця</label>
                            <input type="text" id="street" class="form-control" name="account[street]"/>
                        </div>
                        <div class="form-group">
                            <label for="area" class="col-form-label">Площа квартири, м²</label>
                            <input type="text" id="area" class="form-control" name="account[area]" placeholder="наприклад, 52.30"/>
                            <small class="form-text text-muted">Заповнюйте вручну тільки якщо реєстру немає у файлі. Інакше використовуйте <a href="{{ path('app_admin_area') }}">/admin/area</a>.</small>
                        </div>
                        <div class="form-group">
                            <label class="col-form-label">Персональний поріг блокування за борг</label>
                            <p id="debt_threshold_display" class="form-control-plaintext"><b>—</b></p>
                            <small id="debt_threshold_formula" class="form-text text-muted">Формула: площа × тариф ОСББ × 1.5 (150% місячної плати). Якщо площа не задана — діє запасний поріг.</small>
                        </div>
                        <div class="form-group" style="display:none">
                            <label class="col-form-label">Причина блокування</label>
                            <p id="block_reason_display" class="form-control-plaintext">—</p>
                            <small class="form-text text-muted">Визначається автоматично за поточним станом (борг, відсутнє фото або ручний блок).</small>
                        </div>
                        <div class="form-group">
                            <label for="is_active" class="col-form-label">Статус</label>
                            <input type="checkbox" value="" id="is_active" class="form-control" name="account[is_active]"/>
                        </div>
                        <div class="form-group" id="unblock_reason_group" style="display:none">
                            <label for="unblock_reason" class="col-form-label">Причина розблокування</label>
                            <select id="unblock_reason" class="form-control" name="account[unblock_reason]">
                                <option value="">— оберіть —</option>
                                <option value="photo">📸 Фото надіслано</option>
                                <option value="debt">💰 Борг сплачено</option>
                                <option value="other">📝 Інша причина</option>
                            </select>
                            <small class="form-text text-muted">Використовується для повідомлення користувачу та логування.</small>
                        </div>
                        <div class="form-group" id="block_reason_group" style="display:none">
                            <label for="block_reason" class="col-form-label">Причина блокування</label>
                            <select id="block_reason" class="form-control" name="account[block_reason]">
                                <option value="">— оберіть —</option>
                                <option value="debt">💰 Борг</option>
                                <option value="photo">📸 Не завантажене фото</option>
                                <option value="other">📝 Інша причина</option>
                            </select>
                            <small class="form-text text-muted">Підставляється у повідомлення користувачу — щоб він розумів, чому його заблокували.</small>
                        </div>
                        <div class="form-group">
                            <label class="col-form-label">Борг</label>
                            <p id="debt_display" class="form-control-plaintext">—</p>
                        </div>
                        <div class="form-group" id="status_history_group" style="display:none">
                            <label class="col-form-label"><b>Історія блокувань (останні 5)</b></label>
                            <ul id="status_history_list" class="list-group"></ul>
                            <small class="form-text text-muted">Хто, коли і чому змінив статус акаунту.</small>
                        </div>
                        <hr/>
                        <div class="form-group">
                            <label class="col-form-label"><b>Прив'язані аккаунти (один власник)</b></label>
                            <p class="form-text text-muted">
                                Якщо власник має й квартиру, й паркомісце — прив'яжіть їх, щоб ліміти бронювань і борги рахувалися спільно.
                            </p>
                            <ul id="group_siblings_list" class="list-group mb-2"></ul>
                            <div class="input-group">
                                <input type="text" id="group_link_account_number" class="form-control" placeholder="Особовий рахунок партнера"/>
                                <div class="input-group-append">
                                    <button type="button" id="group_link_btn" class="btn btn-success">Прив'язати</button>
                                </div>
                            </div>
                            <div id="group_link_feedback" class="invalid-feedback" style="display:none;"></div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Назад</button>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('index/js/telegram_users.min') }}

    <script defer>
        console.log('getJSonObject');
        function getJSonObject(value) {
            return $.parseJSON(value.replace(/&quot;/ig, '"'));
        }

        let th_keys = getJSonObject("{{ dataTableKeys ? dataTableKeys|json_encode() : "{}" }}");
        let for_prepare_defs = getJSonObject("{{ dataTableKeys ? dataTableKeys|json_encode() : "{}" }}");
    </script >

    <script src="{{ asset('simditor-2.3.28/site/assets/scripts/module.js') }}" defer></script>
    <script src="{{ asset('simditor-2.3.28/site/assets/scripts/hotkeys.js') }}" defer></script>


    <script src="{{ asset('simditor-2.3.28/lib/simditor.js') }}" defer></script>


{% endblock %}

