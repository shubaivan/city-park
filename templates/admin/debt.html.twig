{% extends 'base.html.twig' %}

{% block title %}Боржники{% endblock %}

{% block body %}
    {{ parent() }}

    <div class="container mt-4">
        <h3>Завантаження файлу боржників</h3>

        <div class="alert alert-info">
            <p class="mb-2"><b>Формат файлу .xlsx</b> — дані починаються з <b>3-го рядка</b>, рядок 1 — заголовок, рядок 2 — назви колонок.</p>
            <table class="table table-bordered table-sm mb-2" style="max-width:480px;background:#fff">
                <thead>
                <tr class="table-light">
                    <th style="width:48px">#</th>
                    <th>A — № кв.</th>
                    <th>B — Особ. рах.</th>
                    <th>C — Борг</th>
                </tr>
                </thead>
                <tbody>
                <tr>
                    <td class="text-muted">3</td>
                    <td>74</td>
                    <td>1010074</td>
                    <td>1350.50</td>
                </tr>
                </tbody>
            </table>
            <p class="mb-2 text-muted">
                Площа квартир оновлюється окремо — через <a href="{{ path('app_admin_area') }}">/admin/area</a> (один реєстр на всі акаунти).
            </p>
            <a href="{{ path('app_admin_debt_example') }}" class="btn btn-sm btn-outline-primary">
                ⬇️ Завантажити приклад .xlsx
            </a>
        </div>

        <form action="{{ path('app_admin_debt_upload') }}" method="post" enctype="multipart/form-data">
            <div class="form-group">
                <label for="debt_file">Файл боржників (.xlsx)</label>
                <input type="file" class="form-control-file" id="debt_file" name="debt_file" accept=".xlsx" required>
            </div>
            <button type="submit" class="btn btn-primary">Завантажити та оновити</button>
        </form>

        {% if result is defined %}
            <div class="mt-4">
                <div class="alert alert-{{ result.success ? 'success' : 'danger' }}">
                    <h5>Результат:</h5>
                    <ul>
                        <li>Оброблено рядків: {{ result.processed }}</li>
                        <li>Оновлено акаунтів: {{ result.updated }}</li>
                        <li>Заблоковано (борг більший за персональний поріг квартири): <b style="color:red">{{ result.blocked }}</b></li>
                        <li>Скинуто борг (не в файлі): <b style="color:green">{{ result.reset }}</b></li>
                        <li>Не знайдено в базі: {{ result.not_found }}</li>
                    </ul>
                    {% if result.missing|length > 0 %}
                        <details open>
                            <summary>Деталі ({{ result.missing|length }})</summary>
                            <ul>
                                {% for acc in result.missing %}
                                    <li>{{ acc }}</li>
                                {% endfor %}
                            </ul>
                        </details>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>

{% endblock %}
