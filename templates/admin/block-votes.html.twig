{% extends 'base.html.twig' %}

{% block title %}Голосування за блокування{% endblock %}

{% block body %}
    {{ parent() }}

    <div class="container">
        <h3 class="mt-3">🗳️ Голосування спільноти за блокування</h3>
        <p class="text-muted">
            Адмін відкриває голосування для кандидата (за особовим рахунком). Голосують усі активні
            квартири, крім кандидата. Якщо «За» проголосує понад половину активних квартир, аккаунт
            автоматично блокується на {{ block_days }} днів (потім — авто-розблокування).
            Голосування триває {{ vote_days }} днів.
        </p>

        <div class="card my-3">
            <div class="card-header">Відкрити нове голосування</div>
            <div class="card-body">
                <form method="post" action="{{ path('app_admin_block_vote_create') }}" class="row g-2 align-items-end">
                    <div class="col-auto">
                        <label class="form-label" for="account_number">Особовий рахунок кандидата</label>
                        <input type="text" class="form-control" id="account_number" name="account_number"
                               placeholder="напр. 1234567" required>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-danger"
                                onclick="return confirm('Відкрити голосування за блокування цього аккаунта? Усі активні квартири отримають повідомлення.');">
                            Відкрити голосування
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <h5>Активні голосування</h5>
        {% if open is empty %}
            <p class="text-muted">Немає відкритих голосувань.</p>
        {% else %}
            <table class="table table-bordered table-sm">
                <thead>
                <tr>
                    <th>Кандидат</th>
                    <th>Рахунок</th>
                    <th>Блок. голосуванням</th>
                    <th>За</th>
                    <th>Проти</th>
                    <th>Треба «За»</th>
                    <th>Активних квартир</th>
                    <th>До</th>
                    <th>Відкрив</th>
                    <th>Дія</th>
                </tr>
                </thead>
                <tbody>
                {% for c in open %}
                    <tr>
                        <td>{{ c.label }}</td>
                        <td>{{ c.account_number }}</td>
                        <td>{% if c.blocks > 0 %}<span class="badge bg-warning text-dark">{{ c.blocks }}×</span>{% else %}—{% endif %}</td>
                        <td><b>{{ c.yes }}</b></td>
                        <td>{{ c.no }}</td>
                        <td>{{ c.needed }}</td>
                        <td>{{ c.eligible }}</td>
                        <td>{{ c.deadline|date('d.m.Y') }}</td>
                        <td>{{ c.created_by ?? '—' }}</td>
                        <td>
                            <form method="post" action="{{ path('app_admin_block_vote_cancel') }}"
                                  onsubmit="return confirm('Скасувати це голосування?');">
                                <input type="hidden" name="campaign_id" value="{{ c.id }}">
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Скасувати</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}

        <h5 class="mt-4">Завершені голосування</h5>
        {% if recent is empty %}
            <p class="text-muted">Поки що немає.</p>
        {% else %}
            <table class="table table-bordered table-sm">
                <thead>
                <tr>
                    <th>Кандидат</th>
                    <th>Рахунок</th>
                    <th>Блок. голосуванням</th>
                    <th>Результат</th>
                    <th>За</th>
                    <th>Проти</th>
                    <th>Треба було «За»</th>
                    <th>Завершено</th>
                </tr>
                </thead>
                <tbody>
                {% for c in recent %}
                    <tr>
                        <td>{{ c.label }}</td>
                        <td>{{ c.account_number }}</td>
                        <td>{% if c.blocks > 0 %}<span class="badge bg-warning text-dark">{{ c.blocks }}×</span>{% else %}—{% endif %}</td>
                        <td>
                            {% if c.status == 'passed' %}<span class="badge bg-danger">Заблоковано</span>
                            {% elseif c.status == 'failed' %}<span class="badge bg-success">Не пройшло</span>
                            {% else %}<span class="badge bg-secondary">Скасовано</span>{% endif %}
                        </td>
                        <td>{{ c.yes ?? 0 }}</td>
                        <td>{{ c.no ?? 0 }}</td>
                        <td>{{ c.needed }}</td>
                        <td>{{ c.closed_at ? c.closed_at|date('d.m.Y H:i') : '—' }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}

        <a href="{{ path('app_admin') }}" class="btn btn-link">← До панелі</a>
    </div>
{% endblock %}
